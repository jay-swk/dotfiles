# ==========================================
# Ghostty Configuration
# docs: https://ghostty.org/docs/config/reference
# ==========================================

# ---------- Font ----------
# D2Coding: 한글 고정폭 (네이버 제작). bootstrap.sh에서 자동 설치.
# JetBrainsMonoNF: Nerd Font 아이콘용 (starship 아이콘, 파일 아이콘 등).
font-family = "D2Coding"
font-family = "JetBrainsMono Nerd Font"
font-size = 14

# ---------- Theme (Dracula) ----------
# tmux/bat/delta와 색상 통일
theme = Dracula

# ---------- Window ----------
window-padding-x = 12
window-padding-y = 10
window-padding-balance = true
window-save-state = always
background-opacity = 0.97
macos-titlebar-style = tabs

# ---------- Cursor ----------
cursor-style = block
cursor-style-blink = true
shell-integration-features = cursor,sudo,title

# ---------- Scrollback ----------
scrollback-limit = 100000

# ---------- Mouse ----------
mouse-hide-while-typing = true
# 드래그 선택 즉시 시스템 클립보드 복사 (tmux의 copy-pipe-and-cancel 'pbcopy'와 동일 효과).
copy-on-select = clipboard
# shift 는 마우스 프로토콜로 보내지 않음 → TUI 앱(Claude Code 등)이 마우스를 캡처해도
# shift+드래그로 항상 텍스트 선택 가능. (tmux mouse on 상태에서도 drag 선택이 되는 것과 동일.)
mouse-shift-capture = false

# ---------- Clipboard (기존 설정 유지) ----------
clipboard-read = allow
clipboard-write = allow
clipboard-paste-protection = false

# ---------- Keybindings ----------
# 한글 IME 활성 상태에서도 Cmd/Ctrl 단축키가 동작하도록 명시적 매핑.
# Ghostty는 기본적으로 W3C physical key 매핑을 쓰지만, macOS NSResponder가
# IME 활성 시 일부 modifier 이벤트를 가로채는 케이스가 있어 unconsumed: 로 우회.
# (tmux에서 raw 키가 잘 전달되는 것과 동일하게 만들어줌)
keybind = unconsumed:super+c=copy_to_clipboard:mixed
keybind = unconsumed:super+v=paste_from_clipboard
keybind = unconsumed:super+a=select_all
keybind = unconsumed:super+f=start_search
keybind = unconsumed:super+t=new_tab
keybind = unconsumed:super+n=new_window
keybind = unconsumed:super+w=close_surface
keybind = unconsumed:super+q=quit
keybind = unconsumed:super+k=clear_screen

# ---------- Ctrl+V IME 우회 (Claude Code 이미지 paste) ----------
# 문제: bare ghostty(no tmux) + 한글 IME 활성 상태에서 Ctrl+V 가 IME 합성 윈도우에
#       흡수돼 Claude Code 에 0x16 인코딩이 전달되지 않음 → 이미지 paste 불가.
# 해결: ctrl+v 를 ghostty 단에서 명시 keybind 로 등록(=IME 가로채기 차단) 하고,
#       text: 액션으로 ^V(0x16) raw 바이트를 stdin 에 직접 주입.
# 주의: `unconsumed:ctrl+v=ignore` 는 동작하지 않음 — `ignore` 는 인코딩 forwarding
#       까지 막아버리기 때문에 ctrl+v 가 영문 모드에서도 죽어버린다.
keybind = ctrl+v=text:\x16
